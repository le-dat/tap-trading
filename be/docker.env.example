# Docker environment variables TEMPLATE — COPY to docker.env and fill values
# docker.env is gitignored; docker.env.example IS committed

# PostgreSQL
POSTGRES_PASSWORD=your_postgres_password

# Redis
REDIS_PASSWORD=your_redis_password

# MinIO (S3-compatible)
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ============================================
# .env.example — Template biến môi trường
# ============================================
# SAO CHÉP file này thành .env.local và điền giá trị thực
# KHÔNG bao giờ commit .env.local lên git!
# ============================================

# ── APP ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Tên Dự Án Của Bạn"
NODE_ENV=development

# ── CLERK (Authentication) ───────────────────
# Lấy tại: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── SUPABASE (Database) ──────────────────────
# Lấy tại: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── STRIPE (Payments) ────────────────────────
# Lấy tại: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs từ Stripe Dashboard
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ── RESEND (Email) ───────────────────────────
# Lấy tại: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── CLOUDFLARE R2 (Storage) ──────────────────
# Lấy tại: Cloudflare Dashboard > R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── ANTHROPIC (AI) ───────────────────────────
# Lấy tại: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── OPTIONAL: MONGODB ────────────────────────
# Dùng nếu chọn MongoDB thay Supabase
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ── OPTIONAL: DIGITAL OCEAN ──────────────────
# Dùng nếu cần backend server riêng
# DO_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL: UPSTASH REDIS ──────────────────
# Dùng cho rate limiting, caching, queues
# UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

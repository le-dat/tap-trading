# ============================================
# .env.example — Tap Trading Environment Variables
# COPY this to .env and .env.local, then fill in real values
# NEVER commit .env or .env.local to git!
# ============================================

# ── APP ──────────────────────────────────────
NODE_ENV=development
PORT=3001
WORKER_PORT=3002
NETWORK=testnet                        # testnet | mainnet

# ── DATABASE (PostgreSQL) ────────────────────
POSTGRES_URL=postgres://root:foobared@localhost:5434/tap

# ── REDIS ────────────────────────────────────
REDIS_URL=redis://default:foobared@localhost:6380/0

# ── KAFKA ────────────────────────────────────
KAFKA_BROKER=localhost:29093
KAFKA_TOPIC_PREFIX=local-tap
KAFKA_RUNNING_FLAG=true

# ── MINIO (S3-compatible storage) ───────────
MINIO_HOST=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=development
MINIO_SECRET_KEY=123456789
BUCKET_NAME=development

# ── EVM / CONTRACTS (BASE Sepolia) ──────────
RPC=https://sepolia.base.org
ADMIN_PRIVATE_KEY=0x...              # Your deployer/admin wallet private key
CONTRACT_TAP_ORDER=0x...             # Deployed TapOrder address
CONTRACT_PAYOUT_POOL=0x...           # Deployed PayoutPool address
CONTRACT_PRICE_FEED_ADAPTER=0x...    # Deployed PriceFeedAdapter address

# ── PRICE FEEDS (BASE Sepolia Chainlink) ────
# Get from https://docs.chain.link/data-feeds/price-feeds/addresses/#Base%20Sepolia
FEED_BTC_USD=0x...                   # BTC/USD Chainlink feed
FEED_ETH_USD=0x...                   # ETH/USD Chainlink feed

# ── AUTH (JWT) ───────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-here

# ── PRIVY (Frontend Wallet Auth) ─────────────
# Get from https://privy.io/dashboard
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-secret

# ── FRONTEND ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_CHAIN_ID=84532             # BASE Sepolia chain ID
NEXT_PUBLIC_TAP_ORDER_ADDRESS=0x...  # Same as CONTRACT_TAP_ORDER
